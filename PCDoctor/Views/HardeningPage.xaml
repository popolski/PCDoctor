<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.HardeningPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels"
    xmlns:svc="using:PCDoctor.Services">

    <Page.DataContext>
        <vm:HardeningViewModel/>
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="20" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Text="Durcissement (Hardening)" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Text="Les interrupteurs reflètent l'état réel. ON = fonctionnalité Windows active."
                       Opacity="0.7" TextWrapping="Wrap"/>

            <!-- LLMNR -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="LLMNR" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Protocole de résolution local. OFF = protégé contre les attaques relay. Recommandé : OFF."
                                   Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch IsOn="{Binding LlmnrActive, Mode=TwoWay}" HorizontalAlignment="Right">
                        <ToolTipService.ToolTip>OFF recommandé — protège contre les attaques relay NTLM</ToolTipService.ToolTip>
                    </ToggleSwitch>
                </Grid>
            </Border>

            <!-- SMBv1 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="SMBv1" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Protocole obsolète et vulnérable (EternalBlue/WannaCry). OFF = sécurisé. Reboot requis."
                                   Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch IsOn="{Binding Smb1Active, Mode=TwoWay}" HorizontalAlignment="Right">
                        <ToolTipService.ToolTip>OFF obligatoire — vulnérable à WannaCry/EternalBlue</ToolTipService.ToolTip>
                    </ToggleSwitch>
                </Grid>
            </Border>

            <!-- SmartScreen / PUA -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Protection PUA (SmartScreen renforcé)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Bloque les applications potentiellement indésirables. ON = activé. Recommandé : ON."
                                   Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch IsOn="{Binding PuaActive, Mode=TwoWay}" HorizontalAlignment="Right">
                        <ToolTipService.ToolTip>ON recommandé — bloque les PUP/adwares automatiquement</ToolTipService.ToolTip>
                    </ToggleSwitch>
                </Grid>
            </Border>

            <!-- mDNS / Bonjour -->
            <TextBlock Text="Protocoles réseau" Style="{StaticResource SectionTitleStyle}"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="mDNS Windows (résolution locale)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" TextWrapping="Wrap">Résolution de noms sur le réseau local sans DNS central. OFF = réduit la surface d'attaque sur les réseaux non fiables. Redémarrage recommandé.</TextBlock>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding MdnsActive, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0" Spacing="4">
                        <TextBlock Text="Bonjour Apple (mDNSResponder)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" TextWrapping="Wrap">Service Apple installé avec iTunes/iCloud. Écoute en permanence sur le réseau. Désactivation recommandée si inutilisé.</TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Désactiver"
                            Command="{Binding DisableBonjourCommand}"
                            IsEnabled="{Binding BonjourInstalled}"
                            VerticalAlignment="Center" Margin="16,0,0,0"/>
                </Grid>
            </Border>

            <!-- Defender -->
            <TextBlock Text="Windows Defender" Style="{StaticResource SectionTitleStyle}"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Signatures antivirus" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="{Binding SignatureInfo}" Opacity="0.7" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Mettre à jour les signatures"
                                Command="{Binding UpdateSignaturesCommand}"
                                IsEnabled="{Binding CanUseDefender}"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"/>
                        <Button Grid.Column="1" Content="Lancer un scan rapide"
                                Command="{Binding QuickScanCommand}"
                                IsEnabled="{Binding CanUseDefender}"
                                HorizontalAlignment="Stretch"/>
                    </Grid>
                    <ProgressBar IsIndeterminate="{Binding IsDefenderBusy}"/>
                </StackPanel>
            </Border>

            <!-- BitLocker -->
            <TextBlock Text="BitLocker" Style="{StaticResource SectionTitleStyle}"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding BitLockerStatusText}" Opacity="0.7" FontSize="12"/>
                    <ItemsControl ItemsSource="{Binding BitLockerDrives}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="svc:BitLockerDrive">
                                <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,6"
                                        Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Drive}" FontWeight="SemiBold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Status}" FontSize="12" Opacity="0.8"/>
                                            <TextBlock Text="{x:Bind EncryptionMethod}" FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{x:Bind ProtectedLabel}"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ASR Rules -->
            <TextBlock Text="Règles ASR (Attack Surface Reduction)" Style="{StaticResource SectionTitleStyle}"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                        Les règles ASR bloquent les vecteurs d'attaque courants (macros, scripts, injections de processus...). Nécessite Windows Defender actif.
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding AsrRules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="svc:AsrRule">
                                <Grid Margin="0,0,0,4" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Icon}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="12" Opacity="0.85" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="Activer toutes les règles ASR"
                            Command="{Binding EnableAllAsrCommand}"
                            IsEnabled="{Binding CanUseAsr}"
                            Style="{StaticResource AccentButtonStyle}"/>
                    <ProgressBar IsIndeterminate="{Binding IsAsrBusy}"/>
                </StackPanel>
            </Border>

            <!-- Exploit Protection -->
            <TextBlock Text="Exploit Protection" Style="{StaticResource SectionTitleStyle}"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0" Spacing="4">
                        <TextBlock Text="DEP / ASLR / SEHOP système" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="{Binding ExploitProtectionText}" Opacity="0.7" FontFamily="Consolas" FontSize="12"/>
                        <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap">
                            Protection système contre l'exploitation de vulnérabilités mémoire. ON = DEP, ASLR (randomisation d'adresses) et SEHOP actifs.
                        </TextBlock>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding ExploitProtectionEnabled, Mode=TwoWay}"
                                  VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <TextBlock Text="{Binding StatusText}" Opacity="0.8" FontStyle="Italic"/>
        </StackPanel>
    </ScrollViewer>
</Page>