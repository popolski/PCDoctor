<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels">

    <Page.DataContext>
        <vm:UpdatesViewModel/>
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="16" MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="Mises a jour Windows" FontSize="32" FontWeight="SemiBold"/>

            <!-- Derniere MAJ installee -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Derniere mise a jour installee" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="{Binding LastUpdate}" Opacity="0.8" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Redemarrage requis -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Redemarrage en attente" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="{Binding RebootText}" Opacity="0.8" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- MAJ en attente -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Mises a jour disponibles" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="{Binding PendingText}" Opacity="0.8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Verifier les MAJ en attente"
                                Command="{Binding CheckPendingCommand}"
                                IsEnabled="{Binding CanCheck}"/>
                        <ProgressRing IsActive="{Binding IsChecking}" Width="24" Height="24"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Politique de mise à jour -->
            <TextBlock Text="Politique de mise à jour" Style="{StaticResource SectionTitleStyle}"/>

            <!-- Bloquer MAJ fonctionnalités -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0" Spacing="4">
                        <TextBlock Text="Bloquer les mises à jour de fonctionnalités" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" TextWrapping="Wrap">
                            ON = Windows reste sur la version actuelle (TargetReleaseVersion). Vous recevez toujours les correctifs de sécurité, mais pas les nouvelles versions (22H2 → 23H2, etc.).
                        </TextBlock>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding FeatureUpdatesBlocked, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0">
                        <ToolTipService.ToolTip>ON = version Windows figée, correctifs de sécurité maintenus</ToolTipService.ToolTip>
                    </ToggleSwitch>
                </Grid>
            </Border>

            <!-- Pause MAJ -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0" Spacing="4">
                        <TextBlock Text="Mettre les mises à jour en pause (4 semaines)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" TextWrapping="Wrap">
                            ON = suspend toutes les MAJ pour 4 semaines (qualité) et 52 semaines (fonctionnalités). Utile pour éviter les mises à jour automatiques non désirées.
                        </TextBlock>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding UpdatesPaused, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0">
                        <ToolTipService.ToolTip>ON = aucune MAJ installée pendant 4 semaines</ToolTipService.ToolTip>
                    </ToggleSwitch>
                </Grid>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                <Button Content="Ouvrir Windows Update"
                        Command="{Binding OpenWindowsUpdateCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="Historique des mises a jour"
                        Command="{Binding OpenHistoryCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
