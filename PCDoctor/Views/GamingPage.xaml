<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.GamingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels">

    <Page.DataContext>
        <vm:GamingViewModel/>
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="16" MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="Gaming" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Text="ON = fonctionnalite active. Optimise les performances en jeu."
                       Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,4"/>

            <!-- Plan Hautes performances -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Plan Hautes performances" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Passe sur le plan Ultimate Performance (ou Hautes performances). OFF = revient sur Equilibre." Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding HighPerfActive, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- Game Mode -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Game Mode Windows" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Optimise l'allocation CPU/GPU quand un jeu est en premier plan. Recommande ON." Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding GameModeActive, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- HAGS -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="GPU Scheduling materiel (HAGS)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Laisse le GPU gerer sa propre file de commandes, reduit la latence. Necessite un GPU compatible." Opacity="0.7" TextWrapping="Wrap"/>
                        <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" CornerRadius="4" Padding="8,4" Margin="0,6,0,0">
                            <TextBlock Text="&#x26A0; Necessite un redemarrage pour prendre effet." FontSize="12" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding HagsActive, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- Xbox Game Bar -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Xbox Game Bar" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="Overlay Xbox (Win+G). OFF = desactive la capture et l'overlay pour reduire l'overhead." Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding GameBarActive, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- Priorite GPU -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Priorite GPU (Win32PrioritySeparation)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="ON = intervalles CPU courts et fixes, boost premier-plan maximal (valeur 38). OFF = valeur Windows standard (2)." Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding GpuPriorityActive, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- Acceleration souris -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Acceleration souris (Enhance Pointer Precision)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="ON = Windows ajuste la vitesse selon le mouvement. OFF recommande en FPS : visee 1:1 avec le capteur." Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding MouseAccelActive, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- Nagle -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Désactiver l'algorithme de Nagle (TCP)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" TextWrapping="Wrap">ON = Nagle desactive (TcpAckFrequency=1, TCPNoDelay=1) : envoie chaque paquet immediatement, reduit la latence reseau en jeu. OFF = comportement TCP standard.</TextBlock>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding NagleDisabled, Mode=TwoWay}" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0"/>
                </Grid>
            </Border>

            <TextBlock Text="{Binding StatusText}" Opacity="0.8" FontStyle="Italic" Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
