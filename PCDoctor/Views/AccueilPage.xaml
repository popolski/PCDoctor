<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.AccueilPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels"
    xmlns:svc="using:PCDoctor.Services">

    <Page.DataContext>
        <vm:AccueilViewModel/>
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="20">

            <InfoBar IsOpen="{Binding UpdateAvailable}"
                     Severity="Informational"
                     IsClosable="True"
                     Title="Mise à jour disponible">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="PCDoctor v"/>
                            <Run Text="{Binding UpdateVersion}"/>
                            <Run Text=" est disponible."/>
                        </TextBlock>
                        <Button Content="Télécharger" Command="{Binding OpenUpdateUrlCommand}"
                                Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>

            <TextBlock Text="Tableau de bord" FontSize="32" FontWeight="SemiBold"/>

            <!-- Infos système -->
            <Grid ColumnSpacing="20" RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="💻 Système" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OsName}" Opacity="0.8"/>
                        <TextBlock Text="{Binding MachineName}" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="🧠 Mémoire vive" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding RamText}" Opacity="0.8"/>
                        <ProgressBar Value="{Binding RamPercent}" Maximum="100"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="🛡️ Sécurité" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DefenderText}" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="⏱️ Uptime" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding UptimeText}" Opacity="0.8"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Text="💾 Disques" FontSize="18" FontWeight="SemiBold"/>
                    <ItemsControl ItemsSource="{Binding Disks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" Margin="0,0,0,8">
                                    <Grid>
                                        <TextBlock Text="{Binding Letter}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Text}" Opacity="0.7" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding Percent}" Maximum="100"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Score de santé -->
            <TextBlock Text="Score de santé" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderThickness="2"
                    BorderBrush="{Binding ScoreColor}">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Score numérique coloré -->
                    <Grid Grid.Column="0" Width="100" Height="100">
                        <ProgressRing IsActive="{Binding HealthLoading}" Width="100" Height="100"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" FontSize="32" FontWeight="Bold"
                                       Foreground="{Binding ScoreColor}">
                                <Run Text="{Binding ScoreOk}"/>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Center" Opacity="0.6" FontSize="13">
                                <Run Text="/"/><Run Text="{Binding ScoreTotal}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="{Binding ScoreText}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{Binding ScoreColor}"/>
                        <ProgressBar Value="{Binding ScoreOk}" Maximum="{Binding ScoreTotal}"
                                     Height="8" Foreground="{Binding ScoreColor}"/>
                        <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap">
                            Vérifications de sécurité, confidentialité et optimisations recommandées.
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Liste des vérifications -->
            <ItemsControl ItemsSource="{Binding HealthChecks}" x:Name="PageRoot">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="svc:HealthCheck">
                        <Button Padding="0" Margin="0,0,0,8" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                IsEnabled="{x:Bind IsClickable}"
                                Command="{Binding DataContext.GoToCheckCommand, ElementName=PageRoot}"
                                CommandParameter="{x:Bind}"
                                Style="{StaticResource TransparentButtonStyle}">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8" Padding="16,12"
                                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" FontSize="20" VerticalAlignment="Center"
                                               Text="{x:Bind Icon}"/>

                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <Grid>
                                            <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"/>
                                            <Border HorizontalAlignment="Right" CornerRadius="4" Padding="6,2"
                                                    Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}">
                                                <TextBlock Text="{x:Bind Category}" FontSize="10" Opacity="0.7"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{x:Bind Advice}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Flèche si cliquable -->
                                    <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="12"
                                              Opacity="{x:Bind ArrowOpacity}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Rapport HTML -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Rapport HTML complet" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                            Génère un rapport HTML sur le Bureau avec l'état de toutes les fonctionnalités : optimisations, confidentialité, hardening, gaming...
                        </TextBlock>
                        <TextBlock Text="{Binding ReportStatus}" Opacity="0.7" FontStyle="Italic" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                        <Button Content="Générer le rapport"
                                Command="{Binding GenerateReportCommand}"
                                IsEnabled="{Binding CanGenerateReport}"
                                Style="{StaticResource AccentButtonStyle}"/>
                        <ProgressBar IsIndeterminate="{Binding IsGeneratingReport}" Width="160"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
