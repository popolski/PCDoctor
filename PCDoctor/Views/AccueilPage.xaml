<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.AccueilPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels"
    xmlns:svc="using:PCDoctor.Services">

    <Page.DataContext>
        <vm:AccueilViewModel/>
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="20">
            <TextBlock Text="Tableau de bord" FontSize="32" FontWeight="SemiBold"/>

            <!-- Infos système -->
            <Grid ColumnSpacing="20" RowSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="💻 Système" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OsName}" Opacity="0.8"/>
                        <TextBlock Text="{Binding MachineName}" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="🧠 Mémoire vive" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding RamText}" Opacity="0.8"/>
                        <ProgressBar Value="{Binding RamPercent}" Maximum="100"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="🛡️ Sécurité" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DefenderText}" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="⏱️ Uptime" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding UptimeText}" Opacity="0.8"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Text="💾 Disques" FontSize="18" FontWeight="SemiBold"/>
                    <ItemsControl ItemsSource="{Binding Disks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" Margin="0,0,0,8">
                                    <Grid>
                                        <TextBlock Text="{Binding Letter}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Text}" Opacity="0.7" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding Percent}" Maximum="100"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Score de santé -->
            <TextBlock Text="Score de santé" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Jauge circulaire simulée avec ProgressRing + texte -->
                    <Grid Grid.Column="0" Width="100" Height="100">
                        <ProgressRing IsActive="{Binding HealthLoading}" Width="100" Height="100"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="Bold">
                                <Run Text="{Binding ScoreOk}"/>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Center" Opacity="0.6" FontSize="13">
                                <Run Text="/"/><Run Text="{Binding ScoreTotal}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="{Binding ScoreText}" FontSize="15" FontWeight="SemiBold"/>
                        <ProgressBar Value="{Binding ScoreOk}" Maximum="{Binding ScoreTotal}"
                                     Height="8"/>
                        <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap">
                            Vérifications de sécurité, confidentialité et optimisations recommandées.
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Liste des vérifications -->
            <ItemsControl ItemsSource="{Binding HealthChecks}" x:Name="PageRoot">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="svc:HealthCheck">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="16,12" Margin="0,0,0,8"
                                BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icône OK / KO -->
                                <TextBlock Grid.Column="0" FontSize="20" VerticalAlignment="Center"
                                           Text="{x:Bind Icon}"/>

                                <StackPanel Grid.Column="1" Spacing="2">
                                    <Grid>
                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"/>
                                        <Border HorizontalAlignment="Right" CornerRadius="4" Padding="6,2"
                                                Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}">
                                            <TextBlock Text="{x:Bind Category}" FontSize="10" Opacity="0.7"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{x:Bind Advice}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
