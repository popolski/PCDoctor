<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.DriversPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Page.DataContext>
        <vm:DriversViewModel/>
    </Page.DataContext>

    <Grid Margin="40" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Pilotes" FontSize="32" FontWeight="SemiBold"/>

        <!-- Barre d'actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
            <Button Content="Analyser" Command="{Binding ScanCommand}" Style="{StaticResource AccentButtonStyle}"/>
            <Button Content="Gestionnaire de peripheriques" Command="{Binding OpenDeviceManagerCommand}"/>
            <Button Content="MAJ optionnelles (pilotes)" Command="{Binding OpenOptionalUpdatesCommand}"/>
            <ProgressRing IsActive="{Binding IsLoading}" Width="24" Height="24" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Recherche -->
        <TextBox Grid.Row="2"
                 PlaceholderText="Filtrer par nom, fournisseur, version..."
                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 MaxWidth="500" HorizontalAlignment="Left"/>

        <!-- DataGrid pilotes -->
        <controls:DataGrid Grid.Row="3"
            ItemsSource="{Binding Drivers}"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            GridLinesVisibility="Horizontal"
            Margin="0,4,0,0">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Peripherique"  Binding="{Binding DeviceName}" Width="3*"/>
                <controls:DataGridTextColumn Header="Fournisseur"   Binding="{Binding Provider}"   Width="2*"/>
                <controls:DataGridTextColumn Header="Version"       Binding="{Binding Version}"    Width="*"/>
                <controls:DataGridTextColumn Header="Date"          Binding="{Binding DateStr}"    Width="*"/>
                <controls:DataGridTextColumn Header="Note"          Binding="{Binding Note}"       Width="*"/>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <TextBlock Grid.Row="4" Text="{Binding StatusText}" Opacity="0.8" FontStyle="Italic" Margin="0,4,0,0"/>
    </Grid>
</Page>
