<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.SettingsPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="20" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Text="Paramètres" FontSize="32" FontWeight="SemiBold"/>

            <!-- Thème -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="🎨 Apparence" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Thème de l'application" Opacity="0.7"/>
                    <ComboBox x:Name="ThemeCombo" SelectionChanged="ThemeCombo_SelectionChanged" Width="220">
                        <ComboBoxItem Content="Suivre le système"/>
                        <ComboBoxItem Content="Clair"/>
                        <ComboBoxItem Content="Sombre"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Journalisation -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="📋 Journalisation" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="PCDoctor trace chaque action sensible dans un fichier de log. Consultez-le pour savoir exactement ce qui a été modifié." Opacity="0.7" TextWrapping="Wrap"/>
                    <Button Content="📂 Ouvrir le dossier de logs" Click="OpenLogs_Click" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Privilèges -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="🔐 Privilèges" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="AdminStatus" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- À propos -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="🩺 À propos de PCDoctor" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="VersionText" Opacity="0.8"/>
                    <TextBlock Text="Boîte à outils d'audit, nettoyage et durcissement de Windows." Opacity="0.7" TextWrapping="Wrap"/>
                    <TextBlock Text="Conçu avec la sécurité par défaut : chaque opération destructrice passe par une analyse en lecture seule, une sélection explicite et une confirmation. Les anti-cheats et composants critiques sont protégés." Opacity="0.6" TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>