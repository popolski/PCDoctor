<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.AuditsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Page.DataContext>
        <vm:AuditsViewModel/>
    </Page.DataContext>

    <Grid Margin="40" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Audits" FontSize="32" FontWeight="SemiBold"/>

        <!-- Boutons d'audit -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
            <Button Content="Services tiers" Command="{Binding RunServicesCommand}"/>
            <Button Content="Drivers" Command="{Binding RunDriversCommand}"/>
            <Button Content="Defender" Command="{Binding RunDefenderCommand}"/>
            <Button Content="Infos système" Command="{Binding RunSystemInfoCommand}"/>
        </StackPanel>

        <!-- Résultats -->
        <Grid Grid.Row="2" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding CurrentTitle}" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CurrentSubtitle}" Opacity="0.7"/>
            </StackPanel>

            <controls:DataGrid Grid.Row="1"
                ItemsSource="{Binding Rows}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="{Binding H1, Mode=OneWay}" Binding="{Binding Col1}" Width="2*"/>
                    <controls:DataGridTextColumn Header="{Binding H2, Mode=OneWay}" Binding="{Binding Col2}" Width="*"/>
                    <controls:DataGridTextColumn Header="{Binding H3, Mode=OneWay}" Binding="{Binding Col3}" Width="*"/>
                    <controls:DataGridTextColumn Header="{Binding H4, Mode=OneWay}" Binding="{Binding Col4}" Width="3*"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Grid>
    </Grid>
</Page>