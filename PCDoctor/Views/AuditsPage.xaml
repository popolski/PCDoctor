<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.AuditsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Page.DataContext>
        <vm:AuditsViewModel/>
    </Page.DataContext>

    <Grid Margin="40" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Audits" FontSize="32" FontWeight="SemiBold"/>

        <!-- Boutons d'audit -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Services tiers"       Command="{Binding RunServicesCommand}"/>
                <Button Content="Drivers"              Command="{Binding RunDriversCommand}"/>
                <Button Content="Defender"             Command="{Binding RunDefenderCommand}"/>
                <Button Content="Infos système"        Command="{Binding RunSystemInfoCommand}"/>
                <Button Content="Extensions shell"     Command="{Binding RunShellExtensionsCommand}"/>
                <Button Content="Grands fichiers"      Command="{Binding RunLargeFilesCommand}"/>
                <Button Content="Extensions navigateur" Command="{Binding RunBrowserExtensionsCommand}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Résultats -->
        <Grid Grid.Row="2" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="{Binding CurrentTitle}" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CurrentSubtitle}" Opacity="0.7"/>
                <ProgressBar IsIndeterminate="{Binding IsBusy}" Margin="0,4,0,0"/>
            </StackPanel>

            <controls:DataGrid Grid.Row="1"
                ItemsSource="{Binding Rows}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Élément" Binding="{Binding Col1}" Width="2*"/>
                    <controls:DataGridTextColumn Header="État / Valeur" Binding="{Binding Col2}" Width="*"/>
                    <controls:DataGridTextColumn Header="Détail" Binding="{Binding Col3}" Width="*"/>
                    <controls:DataGridTextColumn Header="Chemin / Info" Binding="{Binding Col4}" Width="3*"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Grid>
    </Grid>
</Page>