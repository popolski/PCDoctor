<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PCDoctor.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PCDoctor.ViewModels">
    <Page.DataContext>
        <vm:ProfilesViewModel/>
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="20" MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="Profils &amp; Plans" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.7" TextWrapping="Wrap">
                Appliquez un ensemble de tweaks cohérents en un clic, ou choisissez manuellement un plan d'alimentation.
            </TextBlock>

            <!-- Plan d'alimentation -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Plan d'alimentation" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                        Appliqué immédiatement sur toutes les interfaces. "Performances optimales" n'est disponible que sur Windows 10/11 Pro et Workstation.
                    </TextBlock>
                    <ComboBox ItemsSource="{Binding PowerPlanLabels}"
                              SelectedItem="{Binding SelectedPlan, Mode=TwoWay}"
                              MinWidth="300"/>
                </StackPanel>
            </Border>

            <!-- Profils rapides -->
            <TextBlock Text="Profils rapides" FontSize="18" FontWeight="SemiBold" Opacity="0.85"/>
            <TextBlock Opacity="0.65" FontSize="12" TextWrapping="Wrap">
                Chaque profil modifie plusieurs paramètres en même temps. Les résultats sont affichés dans le journal ci-dessous.
            </TextBlock>

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Gaming -->
                <Border Grid.Column="0" Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20"
                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="&#x1F3AE; Gaming" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                            Plan hautes performances, Nagle désactivé, Game Mode ON, HAGS ON, Game Bar OFF, accélération souris OFF, SysMain OFF, Power Throttling OFF.
                        </TextBlock>
                        <Button Content="Appliquer Gaming"
                                Command="{Binding ApplyGamingCommand}"
                                IsEnabled="{Binding CanApply}"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Vie privée -->
                <Border Grid.Column="1" Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20"
                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="&#x1F512; Vie privée" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                            Désactive télémétrie, Cortana, Activity History, Advertising ID, Wi-Fi Sense, apps arrière-plan, Recall, localisation, Copilot et suggestions IA.
                        </TextBlock>
                        <Button Content="Appliquer Vie privée"
                                Command="{Binding ApplyPrivacyCommand}"
                                IsEnabled="{Binding CanApply}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Productivité -->
                <Border Grid.Column="0" Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20"
                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="&#x1F4BB; Productivité" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                            Plan équilibré, extensions et fichiers cachés visibles, chemin complet, "Fin de tâche" activé, NumLock ON, Fast Startup OFF.
                        </TextBlock>
                        <Button Content="Appliquer Productivité"
                                Command="{Binding ApplyProductivityCommand}"
                                IsEnabled="{Binding CanApply}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Équilibré -->
                <Border Grid.Column="1" Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20"
                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="&#x2696;&#xFE0F; Équilibré (défaut)" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                            Remet Windows dans un état standard : plan équilibré, SysMain ON, hibernation ON, Game Mode ON, accélération souris ON, Nagle réactivé.
                        </TextBlock>
                        <Button Content="Appliquer Équilibré"
                                Command="{Binding ApplyBalancedCommand}"
                                IsEnabled="{Binding CanApply}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Journal -->
            <ProgressBar IsIndeterminate="{Binding IsApplying}"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Journal" FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock Text="{Binding LogText}" FontFamily="Consolas" FontSize="11"
                               Opacity="0.85" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusText}" Opacity="0.8" FontStyle="Italic"/>
        </StackPanel>
    </ScrollViewer>
</Page>
